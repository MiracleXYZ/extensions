{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "wishapp",
  "title": "WishApp",
  "description": "Add products to your WishApp wishlists and browse them from Raycast.",
  "icon": "command-icon.png",
  "author": "bilal_k",
  "categories": [
    "Productivity"
  ],
  "keywords": [
    "wishlist",
    "shopping",
    "gift",
    "registry"
  ],
  "platforms": [
    "macOS",
    "Windows"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "add-to-wishlist",
      "title": "Add to Wishlist",
      "subtitle": "WishApp",
      "description": "Save a product URL to one of your wishlists.",
      "mode": "view"
    },
    {
      "name": "my-wishlists",
      "title": "My Wishlists",
      "subtitle": "WishApp",
      "description": "Browse and open your wishlists.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "API Key",
      "type": "password",
      "required": true,
      "description": "Your WishApp API key. Generate one at getwish.app/settings and paste it here.",
      "placeholder": "wish_…"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.0",
    "@raycast/utils": "^2.2.5",
    "country-data-list": "^1.6.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}

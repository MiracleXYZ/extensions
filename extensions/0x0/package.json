{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "0x0",
  "title": "0x0",
  "description": "Upload files to https://0x0.st.",
  "icon": "icon.png",
  "author": "pseudobun",
  "contributors": [
    "pernielsentikaer",
    "jatindotdev",
    "0xdhrv"
  ],
  "license": "MIT",
  "categories": [
    "Applications",
    "Media"
  ],
  "commands": [
    {
      "name": "index",
      "title": "Upload File",
      "subtitle": "0x0",
      "description": "Select a file and upload it to 0x0.st.",
      "mode": "view"
    },
    {
      "name": "history",
      "title": "Upload History",
      "subtitle": "0x0",
      "description": "Browse, open, and delete your uploaded files.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "instanceUrl",
      "type": "textfield",
      "required": false,
      "title": "Instance URL",
      "description": "The 0x0 instance to upload to. Use this to point to a self-hosted instance (including localhost).",
      "default": "https://0x0.st",
      "placeholder": "https://0x0.st"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.21",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/react": "19.2.17",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ],
  "engines": {
    "node": ">=24"
  }
}

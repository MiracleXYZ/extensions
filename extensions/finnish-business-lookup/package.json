{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "finnish-business-lookup",
  "title": "FBL - Finnish Business Lookup",
  "description": "Look up Finnish businesses by name or Business ID using PRH YTJ open data",
  "icon": "icon.png",
  "author": "eljn",
  "access": "public",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "prh-search",
      "title": "Search Finnish Businesses",
      "description": "Look up Finnish businesses by name or Business ID using PRH YTJ open data",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.23",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.0"
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}

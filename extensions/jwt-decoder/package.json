{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "jwt-decoder",
  "title": "JWT Decoder",
  "description": "Decode Your JSON Web Tokens - extract the header and data information from a JWT",
  "icon": "icon.png",
  "author": "gdsmith",
  "contributors": [
    "zhhanging",
    "joaogf.dev",
    "YourMCGeek",
    "pernielsentikaer",
    "ridemountainpig",
    "0xdhrv"
  ],
  "categories": [
    "Data",
    "Developer Tools",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "jwt-view",
      "title": "View Decoded JWT",
      "description": "View and copy the contents your JWT",
      "mode": "view"
    },
    {
      "name": "jwt-list",
      "title": "Search Decoded JWT",
      "description": "Search and copy the contents of your JWT",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.21",
    "csv-parse": "^7.0.1",
    "jose": "^6.2.3",
    "raycast-hooks": "^1.0.4"
  },
  "peerDependencies": {
    "react": "19.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "26.1.0",
    "@types/react": "^19.2.17",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "react": "19.2.7",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}

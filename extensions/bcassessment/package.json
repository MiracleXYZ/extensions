{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "bcassessment",
  "title": "BC Assessment",
  "description": "Search BC Assessment properties by address.",
  "icon": "extension-icon.png",
  "author": "martins",
  "categories": [
    "Finance"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-address",
      "title": "Search Address",
      "description": "Find matching BC Assessment addresses.",
      "icon": "extension-icon.png",
      "mode": "view",
      "keywords": [
        "bcass",
        "bca",
        "bcassessment"
      ],
      "arguments": [
        {
          "name": "address",
          "placeholder": "Address",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.22"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}

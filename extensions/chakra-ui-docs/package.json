{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "chakra-ui-docs",
  "title": "Chakra UI Documentation",
  "description": "Provide quick links to the Chakra UI component documentation.",
  "icon": "chakra.png",
  "author": "pgvr",
  "contributors": [
    "Ansub",
    "stanley_ding",
    "xmok"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "get-started",
      "title": "Get Started",
      "subtitle": "Chakra UI",
      "keywords": [
        "get started"
      ],
      "description": "Get Started with Chakra UI",
      "mode": "view"
    },
    {
      "name": "styled-system",
      "title": "Search Styled System",
      "subtitle": "Chakra UI",
      "keywords": [
        "styled system"
      ],
      "description": "Styled System of Chakra UI",
      "mode": "view"
    },
    {
      "name": "components",
      "title": "Search Components",
      "subtitle": "Chakra UI",
      "keywords": [
        "components"
      ],
      "description": "Components of Chakra UI",
      "mode": "view"
    },
    {
      "name": "hooks",
      "title": "Search Hooks",
      "subtitle": "Chakra UI",
      "keywords": [
        "hooks"
      ],
      "description": "Hooks of Chakra UI",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.21",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/uuid": "^10.0.0",
    "axios": "^1.8.4",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish",
    "doc:update-component": "npx tsx utils/updateComponentsDoc.ts && ray lint --fix"
  },
  "platforms": [
    "macOS"
  ]
}

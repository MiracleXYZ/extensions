{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "DOM"],
    "jsx": "react",
    "module": "Node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
